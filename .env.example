NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Payload + PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/ats
PAYLOAD_SECRET=change-this-to-a-long-random-secret

# Candidate invitation flow (Phase 6)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=noreply@your-domain.com
CANDIDATE_INVITE_TOKEN_TTL_HOURS=72
RESEND_API_KEY=re_xxxxxxxxx # Replace with your real Resend API key
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_TEST_TO_EMAIL=manojkarajada.mk@gmail.com

# S3 / R2-compatible storage (Phase 2+)
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=
